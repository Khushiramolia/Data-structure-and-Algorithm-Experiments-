\section{Algorithms and Time Complexity for Real-Time Stream Processing}
% ============================================================

\vspace{1em}

\subsection{Probabilistic and Sketch-Based Structures}

Probabilistic and sketch-based data structures form the backbone of modern streaming analytics.  
These algorithms trade exactness for memory efficiency and speed, providing constant or sublinear space approximations.  
In domains like network telemetry, IoT, and social data monitoring, they enable approximate frequency counts, distinct element tracking, and anomaly detection in unbounded data streams.

% ------------------------------------------------------------
\noindent\textbf{1. Bloom Filter}

\begin{algorithm}
\caption{Bloom Filter for Streaming Membership Testing}
\begin{algorithmic}[1]
\Procedure{Insert}{$x, k, H, B$}
    \For{$i = 1$ to $k$}
        \State $h_i \gets H_i(x) \bmod |B|$
        \State $B[h_i] \gets 1$
    \EndFor
\EndProcedure
\Procedure{Query}{$x, k, H, B$}
    \For{$i = 1$ to $k$}
        \If{$B[H_i(x) \bmod |B|] == 0$}
            \State \Return False
        \EndIf
    \EndFor
    \State \Return True
\EndProcedure
\end{algorithmic}
\end{algorithm}

\textbf{Overview:}
The Bloom Filter is a compact probabilistic structure used for membership queries in streaming data.  
It uses $k$ hash functions and a bit array $B$ of size $m$ to indicate whether an element might belong to a set.  
False positives are possible, but false negatives are not.  
It is extensively applied in web caching, packet filtering, and deduplication of high-speed streaming data.

\begin{tcolorbox}
\textbf{Time Complexity:}  
Insertion and query both require $O(k)$ time, where $k$ is constant (typically 3–7).  
Space: $O(m)$ bits.  
False positive probability $\approx (1 - e^{-kn/m})^k$.  
Reference: [7]
\end{tcolorbox}

% ------------------------------------------------------------
\noindent\textbf{2. Count-Min Sketch}

\textbf{Overview:}
The Count-Min Sketch is a probabilistic summary for approximate frequency estimation in large-scale data streams.  
It uses $d$ hash functions mapping to $w$ counters, maintaining compressed frequency views.  
Errors are upper-bounded by $\epsilon N$ with confidence $1-\delta$, making it invaluable in network analytics, heavy-hitter detection, and anomaly tracking.

\begin{algorithm}
\caption{Count-Min Sketch for Frequency Estimation}
\begin{algorithmic}[1]
\Procedure{Update}{$x, c, d, w, C$}
    \For{$i = 1$ to $d$}
        \State $C[i, h_i(x)] \gets C[i, h_i(x)] + c$
    \EndFor
\EndProcedure
\Procedure{Estimate}{$x, d, C$}
    \State \Return $\min_{i=1..d} C[i, h_i(x)]$
\EndProcedure
\end{algorithmic}
\end{algorithm}


\begin{tcolorbox}
\textbf{Time Complexity:}  
Update/query: $O(d)$ per element ($d = O(\log(1/\delta))$).  
Space: $O(dw)$ counters.  
Reference: [8]
\end{tcolorbox}

% ------------------------------------------------------------
\noindent\textbf{3. HyperLogLog}

\begin{algorithm}
\caption{HyperLogLog for Cardinality Estimation}
\begin{algorithmic}[1]
\Procedure{Insert}{$x, m, M$}
    \State $h \gets \text{hash}(x)$
    \State $j \gets \text{first } b \text{ bits of } h$
    \State $r \gets \text{rank of first 1 in remaining bits}$
    \State $M[j] \gets \max(M[j], r)$
\EndProcedure
\Procedure{Estimate}{$m, M$}
    \State $Z \gets (\sum_{j=1}^{m} 2^{-M[j]})^{-1}$
    \State \Return $\alpha_m m^2 Z$
\EndProcedure
\end{algorithmic}
\end{algorithm}

\textbf{Overview:}
HyperLogLog is a state-of-the-art algorithm for estimating distinct elements (cardinality) in massive streams.  
It partitions hash outputs into $m=2^b$ buckets and records the longest run of leading zeros per bucket.  
It achieves near-constant relative error with logarithmic space, ideal for clickstream, IoT, and social data platforms.

\begin{tcolorbox}
\textbf{Time Complexity:}  
Insert: $O(1)$; Estimate: $O(m)$; Space: $O(m)$ registers (5–8 bits).  
Reference: [9]
\end{tcolorbox}

% ------------------------------------------------------------
\noindent\textbf{4. Cuckoo Filter}
\textbf{Overview:}
Cuckoo Filters extend Bloom Filters with deletions and improved false-positive control.  
Each fingerprint can be stored in two possible buckets; if both are full, one entry is displaced recursively.  
They are widely used in online deduplication and dynamic stream indexing.

\begin{algorithm}
\caption{Cuckoo Filter for Membership Queries}
\begin{algorithmic}[1]
\Procedure{Insert}{$x, B$}
    \State $f \gets \text{fingerprint}(x)$
    \State $i_1 \gets h(x)$; $i_2 \gets i_1 \oplus h(f)$
    \If{bucket $i_1$ or $i_2$ has space}
        \State insert $f$
    \Else
        \State evict existing fingerprint and reinsert displaced
    \EndIf
\EndProcedure
\Procedure{Query}{$x$}
    \Return $f \in B[i_1] \lor f \in B[i_2]$
\EndProcedure
\end{algorithmic}
\end{algorithm}



\begin{tcolorbox}
\textbf{Time Complexity:}  
Insertion: $O(1)$ expected, $O(\log n)$ worst-case; Query: $O(1)$.  
Space: $O(n)$ fingerprints.  
Reference: [10]
\end{tcolorbox}

% ------------------------------------------------------------
\noindent\textbf{5. KLL Sketch}
\textbf{Overview:}
The KLL Sketch approximates quantiles efficiently in real-time data streams.  
It maintains hierarchical buffers that are compacted when full, preserving relative rank accuracy.  
Highly space-efficient for median or percentile queries in telemetry, stock analytics, and anomaly detection.

\begin{algorithm}
\caption{KLL Sketch for Quantile Approximation}
\begin{algorithmic}[1]
\Procedure{Insert}{$x$}
    \State append $x$ to smallest level
    \If{level full}
        \State compact by sorting and keeping every second element
        \State propagate summary to next level
    \EndIf
\EndProcedure
\Procedure{EstimateQuantile}{$\phi$}
    \State merge all levels and return rank $\phi$
\EndProcedure
\end{algorithmic}
\end{algorithm}



\begin{tcolorbox}
\textbf{Time Complexity:}  
Insert: $O(\log(1/\epsilon))$ amortized; Query: $O(1/\epsilon)$; Space: $O((1/\epsilon)\log\log(1/\epsilon))$.  
Reference: [11]
\end{tcolorbox}

% ------------------------------------------------------------
\noindent\textbf{6. Top-K Sketch}
\textbf{Overview:}
The Top-K Sketch tracks the most frequent items in streaming data under strict memory limits.  
Using a min-heap and approximate counters, it continuously updates top elements.  
Useful in trend analysis, content caching, and fraud monitoring.
\begin{algorithm}
\caption{Top-K Sketch for Heavy-Hitter Detection}
\begin{algorithmic}[1]
\Procedure{Update}{$x, c$}
    \If{$x$ in heap}
        \State increment its count
    \Else
        \If{heap not full}
            \State insert $(x,c)$
        \Else
            \State replace smallest-count entry
        \EndIf
    \EndIf
\EndProcedure
\Procedure{GetTopK}{}
    \State \Return elements with highest counts
\EndProcedure
\end{algorithmic}
\end{algorithm}


\begin{tcolorbox}
\textbf{Time Complexity:}  
Update: $O(\log K)$; Query: $O(K)$; Space: $O(K)$ counters.  
Reference: [12]
\end{tcolorbox}

